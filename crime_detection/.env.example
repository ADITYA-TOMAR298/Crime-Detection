# Frontend: set this in Vercel (must be the public Cloud Run URL, no trailing slash)
# VITE_API_URL=https://YOUR-CLOUD-RUN-SERVICE.a.run.app

# Backend: set this to your Vercel production URL and any preview URLs that need access.
CORS_ORIGINS=http://localhost:5173,https://YOUR-PROJECT.vercel.app
PUBLIC_API_URL=https://YOUR-CLOUD-RUN-SERVICE.a.run.app

# Cloud Run has no user webcam. Set an RTSP URL to enable live detection.
# CAMERA_SOURCE=rtsp://camera-host:554/stream
# PIPELINE_ENABLED=true

# SQLite is for local development only. Use managed Postgres for Cloud Run.
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DATABASE
